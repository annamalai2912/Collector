{
  "name": "Link Vault",
  "short_name": "LinkVault",
  "description": "Personal Tool & GitHub Repo Vault",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0d1117",
  "theme_color": "#161b22",
  "icons": [
    {
      "src": "/favicon.ico",
      "sizes": "64x64 32x32 24x24 16x16",
